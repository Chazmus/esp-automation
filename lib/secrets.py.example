# Rename this file to secrets.py and fill in your actual credentials.
# secrets.py is excluded from git source control to keep your credentials private.

WIFI_SSID = "your-wifi-ssid"
WIFI_PASSWORD = "your-wifi-password"

# Home Assistant Configuration
# Note: Use the local IP address (e.g., http://192.168.1.100:8123) instead of .local
HA_URL = "http://your-homeassistant-ip:8123"
HA_TOKEN = "your-long-lived-access-token"

# Unique identifier for this physical board (used to distinguish entities in HA)
# Example: "living_room", "bedroom", "garage", "kitchen"
DEVICE_NAME = "living_room"

# WebREPL Password (must be 4-9 characters long)
WEBREPL_PASSWORD = "your-pass"

# Optional: Static IP configuration (IP, Subnet Mask, Gateway, DNS Server)
# If not defined or set to None, the board will fall back to DHCP dynamically.
# Example:
# WIFI_STATIC_IP = ("192.168.86.50", "255.255.255.0", "192.168.86.1", "192.168.86.1")
WIFI_STATIC_IP = None


