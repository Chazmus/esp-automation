# Rename this file to secrets.yaml and fill in your actual credentials.
# secrets.yaml is excluded from git source control to keep your credentials private.

wifi_ssid: "your-wifi-name"
wifi_password: "your-wifi-password"

# Home Assistant API encryption key (32 random bytes, base64-encoded).
# Generate one with: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "your-generated-key"

# OTA update password (used for encrypted over-the-air firmware updates after the first flash).
ota_password: "your-ota-password"
